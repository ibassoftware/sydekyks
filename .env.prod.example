# Copy to `.env` on the server (next to docker-compose.prod.yml) and fill in real values.
# docker compose reads `.env` automatically. NEVER commit the filled-in .env.

# ---- Domains / TLS ---------------------------------------------------------
# The public app domain (must have an A record pointing at this server's IP).
APP_DOMAIN=sydekyks.com
# Email Let's Encrypt uses for cert expiry notices.
ACME_EMAIL=ops@sydekyks.com
# Domain inbound bills are received on (MX -> Postmark). Also set in the Command Center UI.
EMAIL_INBOUND_DOMAIN=inbound.sydekyks.com

# ---- Secrets (generate fresh — do NOT reuse the dev defaults) --------------
# Postgres password for the app DB.
POSTGRES_PASSWORD=change-me-strong-random
# Password for LiteLLM's own Postgres.
LITELLM_POSTGRES_PASSWORD=change-me-strong-random
# JWT signing secret:            openssl rand -hex 32
JWT_SECRET=change-me
# LiteLLM master key:            sk-<random>
LITELLM_MASTER_KEY=sk-change-me
# Fernet key for encrypting stored secrets (Odoo creds, provider keys, Postmark token).
# CRITICAL: generate ONCE and keep stable forever — changing it makes all stored secrets undecryptable.
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change-me

# ---- Bootstrap super-admin -------------------------------------------------
ADMIN_EMAIL=rein@ibasuite.com
ADMIN_PASSWORD=change-me-strong

# ---- Inbound email webhook (Postmark) Basic Auth ---------------------------
# These are the creds Postmark must include in the webhook URL; also editable later in the Command Center.
EMAIL_WEBHOOK_BASIC_AUTH_USER=postmark
EMAIL_WEBHOOK_BASIC_AUTH_PASS=change-me-strong
